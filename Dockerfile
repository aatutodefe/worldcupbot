# 1. Базовый образ: легкая версия Python 3.11
FROM python:3.11-slim

# 2. Устанавливаем переменную окружения, чтобы Python не создавал .pyc файлы и выводил логи сразу
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# 3. Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# 4. Копируем файл зависимостей в контейнер
COPY requirements.txt .

# 5. Устанавливаем библиотеки из requirements.txt
# Флаг --no-cache-dir уменьшает размер итогового образа
RUN pip install --no-cache-dir -r requirements.txt

# 6. Копируем ВСЕ остальные файлы из текущей папки на компьютере в папку /app внутри контейнера
COPY . .

# 7. Команда, которая запустит вашего бота при старте контейнера
# ЗАМЕНИТЕ 'main.py' на название вашего главного файла (например, bot.py или app.py)
CMD ["python", "bot.py"]